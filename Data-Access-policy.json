[
  {
    "Rules": [
      {
        "Resource": [
          "collection/<Collection-Name>"
        ],
        "Permission": [
          "aoss:CreateCollectionItems",
          "aoss:DeleteCollectionItems",
          "aoss:UpdateCollectionItems",
          "aoss:DescribeCollectionItems"
        ],
        "ResourceType": "collection"
      },
      {
        "Resource": [
          "index/<Collection-Name>/*"
        ],
        "Permission": [
          "aoss:CreateIndex",
          "aoss:DeleteIndex",
          "aoss:UpdateIndex",
          "aoss:DescribeIndex",
          "aoss:ReadDocument",
          "aoss:WriteDocument"
        ],
        "ResourceType": "index"
      }
    ],
    "Principal": [
      "<ARN-of-the-user>",
      "<ARN of the-role-created>"
    ],
    "Description": "Rule 1"
  },
  {
    "Rules": [
      {
        "Resource": [
          "model/<Collection-Name>/*"
        ],
        "Permission": [
          "aoss:CreateMLResource",
          "aoss:DeleteMLResource",
          "aoss:UpdateMLResource",
          "aoss:DescribeMLResource",
          "aoss:ExecuteMLResource"
        ],
        "ResourceType": "model"
      }
    ],
    "Principal": [
      "<ARN-of-the-user>",
      "<ARN of the-role-created>"
    ],
    "Description": "Rule 1 - Model Permissions"
  }
]
